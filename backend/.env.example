# ===== LLM Providers =====
# OpenAI (primary). Lấy key tại https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (fallback). Lấy key tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== Orchestrator =====
# Dưới ngưỡng confidence này -> degrade về GENERAL_GREETING (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.6
