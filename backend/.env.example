# ============================================================================
# AI Email Assistant — backend configuration
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Model names are explicit configuration because provider availability changes.
# ============================================================================

# ----- Groq (PRIMARY for both summarizer and orchestrator) -----
# e.g. GROQ_MODEL=llama-3.3-70b-versatile  (see console.groq.com/docs/models)
GROQ_API_KEY=replace-me
GROQ_MODEL=replace-with-an-available-groq-model

# ----- Gemini (FALLBACK for both summarizer and orchestrator) -----
# If Groq is unset/fails, both fall back to Gemini, then the orchestrator falls
# back to a keyword-based mock so the flow still runs without any keys.
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash

# ----- Summarizer tuning (optional; defaults shown) -----
SUMMARIZER_MAX_MESSAGES=20
SUMMARIZER_MAX_NORMALIZED_CHARS=100000
SUMMARIZER_PROVIDER_TIMEOUT_SECONDS=30
SUMMARIZER_RETRY_DELAY_SECONDS=0.25

# ----- Orchestrator tuning (optional; default shown) -----
# Routing decisions below this confidence degrade to the safe fallback template.
CONFIDENCE_THRESHOLD=0.6

# ----- AutoReply & Whitelist Workflow (optional; defaults shown) -----
# TTL for the in-memory whitelist match cache. 0 = disabled.
WHITELIST_CACHE_TTL_SECONDS=60
# Processing delay before draft generation starts
AUTO_REPLY_WORKFLOW_DELAY_SECONDS=0.0
# Max retry attempts for transient workflow failures
AUTO_REPLY_MAX_RETRIES=3
# Base delay between retry attempts (exponential back-off)
AUTO_REPLY_RETRY_DELAY_SECONDS=1.0
# Maximum number of rows accepted in a single CSV/Excel import
BULK_IMPORT_MAX_ROWS=10000
