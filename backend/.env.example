# Both model names are explicit configuration because provider availability changes.
GROQ_API_KEY=replace-me
GROQ_MODEL=replace-with-an-available-groq-model
GEMINI_API_KEY=replace-me
GEMINI_MODEL=replace-with-an-available-gemini-model

SUMMARIZER_MAX_MESSAGES=20
SUMMARIZER_MAX_NORMALIZED_CHARS=100000
SUMMARIZER_PROVIDER_TIMEOUT_SECONDS=30
SUMMARIZER_RETRY_DELAY_SECONDS=0.25
